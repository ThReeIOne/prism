FROM golang:1.24-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /bin/prism-collector ./cmd/collector

FROM alpine:3.19
RUN apk --no-cache add ca-certificates
COPY --from=builder /bin/prism-collector /usr/local/bin/prism-collector
ENTRYPOINT ["prism-collector"]
